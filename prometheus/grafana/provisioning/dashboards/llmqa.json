{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "LLM-QA-OPS-LAB — Step 13 observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Evaluation Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Eval Request Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(llmqa_eval_requests_total[5m]))", "legendFormat": "req/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 1 },
      "id": 2,
      "options": { "pieType": "donut", "displayLabels": ["percent", "name"] },
      "title": "Evaluation Status Distribution",
      "type": "piechart",
      "targets": [
        { "expr": "sum by(status)(increase(llmqa_eval_requests_total[1h]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Evaluation Score Distribution (p50 / p95)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(llmqa_eval_score_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(llmqa_eval_score_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 101,
      "title": "🔍 RAG Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.2 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 11 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "RAG Retrieval p95 Latency",
      "type": "stat",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(llmqa_rag_retrieval_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.4 },
            { "color": "green", "value": 0.6 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 11 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "RAG Hit Rate",
      "type": "stat",
      "targets": [
        { "expr": "sum(rate(llmqa_rag_requests_total{retrieval=\"hit\"}[15m])) / sum(rate(llmqa_rag_requests_total[15m]))", "legendFormat": "hit rate" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 11 },
      "id": 12,
      "title": "RAG Retrieval Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(llmqa_rag_retrieval_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(llmqa_rag_retrieval_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(llmqa_rag_retrieval_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "🌐 HTTP Latency SLO",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 0.5 }
          ]}
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 20,
      "title": "POST /evaluate — Latency p50 / p95 (SLO: p95 < 500ms)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=\"/evaluate\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=\"/evaluate\"}[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.2 },
            { "color": "red", "value": 0.3 }
          ]}
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 21,
      "title": "POST /evaluate/rag — Latency p50 / p95 (SLO: p95 < 300ms)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=\"/evaluate/rag\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=\"/evaluate/rag\"}[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 103,
      "title": "🤖 Agent Loop Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 30,
      "title": "Agent Loop — Iterations per minute",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(llmqa_agent_loop_iterations_total[1m]) * 60", "legendFormat": "iterations/min" },
        { "expr": "rate(llmqa_agent_loop_errors_total[1m]) * 60", "legendFormat": "errors/min" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 31,
      "title": "Action Executor — Actions by type",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by(action_type)(rate(llmqa_action_executor_total[5m]))", "legendFormat": "{{action_type}}" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["llm-qa-ops", "step-13", "slo"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LLM-QA-OPS-LAB — Observability",
  "uid": "llmqa-main",
  "version": 1
}
