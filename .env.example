# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required for IncidentCopilot AI reasoning (Step 1 of the roadmap).
# Get your key at: https://platform.openai.com/api-keys
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
OPENAI_API_KEY=sk-...

# ─── Optional: override the default model ────────────────────────────────────
# Default is gpt-4o-mini (fast, cheap, great for structured JSON output).
# Set to gpt-4o for more powerful reasoning.
# OPENAI_MODEL=gpt-4o-mini

# ─── PostgreSQL (Step 3) ──────────────────────────────────────────────────────
# Connection string for the SQLAlchemy engine in eval-py.
# The Docker container is started with:
#   docker run -d --name llmqa-postgres \
#     -e POSTGRES_USER=llmqa -e POSTGRES_PASSWORD=llmqa_dev -e POSTGRES_DB=llmqa \
#     -p 5434:5432 postgres:15
#
DB_URL=postgresql://llmqa:llmqa_dev@localhost:5434/llmqa

# ─── Redis (Step 6) ───────────────────────────────────────────────────────────
# Used for caching GET /metrics and GET /analytics (cache-aside, TTL 30 s).
# The Docker container is started with:
#   docker run -d --name llmqa-redis -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379
